{
  "name": "simdash-configurator",
  "version": "1.0.0",
  "description": "Desktop Configurator for SimDash ESP32 Tachometer",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder"
  },
  "devDependencies": {
    "electron": "^28.2.0",
    "electron-builder": "^26.15.3"
  },
  "build": {
    "appId": "com.nettezy.simdash-configurator",
    "win": {
      "target": "portable"
    },
    "files": [
      "main.js",
      "package.json",
      "web-tool.html"
    ],
    "directories": {
      "output": "dist"
    }
  }
}
